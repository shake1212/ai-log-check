# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/ai_log_system?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# JWT 配置（生产环境请替换为随机长字符串，至少 32 位）
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
JWT_EXPIRATION=86400000
